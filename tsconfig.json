{
  "compilerOptions": {
    // 1. Xóa hoặc comment dòng baseUrl cũ
    // "baseUrl": ".", 

    // 2. Thêm dòng này để tắt cảnh báo nếu TypeScript phiên bản > 5.5
    "ignoreDeprecations": "5.0",

    "paths": {
      // 3. Đảm bảo path ánh xạ đúng. 
      // Nếu code nằm trong src: "@/*": ["./src/*"]
      // Nếu code nằm ở root: "@/*": ["./*"]
      "@/*": ["./*"]
    },
    
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false, // Khuyên bạn nên để true để quản lý phòng trọ ít lỗi hơn
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "app/**/*.css",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "eslint.config.mjs"
  ]
}