generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Khôi phục lại dòng này
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Lưu hash mật khẩu
  fullName  String
  phone     String
  role      String   @default("ADMIN") // Chỉ có ADMIN hoặc STAFF
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}


// 1. Bảng Danh mục Phòng
model Room {
  id           String   @id @default(cuid())
  roomNumber   String   @unique
  basePrice    Float
  // Thông tin khách thuê lưu trực tiếp ở đây, không cần bảng User riêng cho khách
  tenantName   String?
  tenantPhone  String?
  tenantEmail  String?  // Email này để hệ thống tự động gửi thông báo

  // Trạng thái phòng: true là đang cho thuê/hoạt động, false là ngưng
  isActive     Boolean  @default(true)
  
  meterReadings MeterReading[]
  bills         Bill[]
}

// 2. Bảng Cấu hình & Lịch sử giá
model PriceConfig {
  id            String   @id @default(cuid())
  electricPrice Float    // Đơn giá điện
  waterPrice    Float    // Đơn giá nước
  effectiveDate DateTime @default(now())
  isActive      Boolean  @default(true) // Chỉ duy nhất 1 bản ghi có true để lấy giá hiện hành
}

// 3. Bảng Theo dõi chỉ số (Nhập liệu hàng tháng)
model MeterReading {
  id           String   @id @default(cuid())
  month        Int      // Tháng (1-12)
  year         Int      // Năm
  
  electricOld  Float
  electricNew  Float
  waterOld     Float
  waterNew     Float
  
  createdAt    DateTime @default(now())

  // Quan hệ với Room
  roomId       String
  room         Room     @relation(fields: [roomId], references: [id])
  
  // Quan hệ 1-1 với Bill (Chốt chỉ số xong là có Bill ngay)
  bill         Bill?
}

// 4. Bảng Bill & Trạng thái thanh toán
model Bill {
  id            String      @id @default(cuid())
  totalAmount   Float       // Tổng tiền tính toán cuối cùng
  status        BillStatus  @default(PENDING)
  paidAt        DateTime?   // Ngày thực tế khách trả tiền
  emailSent     Boolean     @default(false)
  
  // Lưu vết giá tại thời điểm xuất hóa đơn để đối chiếu
  appliedElectricPrice Float
  appliedWaterPrice    Float
  appliedBasePrice     Float

  // Quan hệ
  roomId        String
  room          Room         @relation(fields: [roomId], references: [id])
  
  readingId     String       @unique
  meterReading  MeterReading @relation(fields: [readingId], references: [id])

  createdAt     DateTime     @default(now())
}

enum BillStatus {
  PENDING   // Chờ thanh toán
  PAID      // Đã thanh toán
  OVERDUE   // Quá hạn
}